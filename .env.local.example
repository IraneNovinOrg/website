# NextAuth
NEXTAUTH_URL=https://iranenovin.com
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# GitHub OAuth App (for user login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth App
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub Bot Token (Personal Access Token of iranenovin-bot account)
# Needs scopes: repo, admin:org, write:discussion, read:org
GITHUB_BOT_TOKEN=

# GitHub Org config
GITHUB_ORG=IranENovin
GITHUB_IDEAS_REPO=ideas
GITHUB_IDEAS_CATEGORY_ID=

# Resend (for invite emails and confirmations)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@iranenovin.com

# App URL
NEXT_PUBLIC_APP_URL=https://iranenovin.com
NEXT_PUBLIC_COMMUNITY_PATH=/community
